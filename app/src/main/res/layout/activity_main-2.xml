<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#6200EE"
        android:padding="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8592;"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:backgroundTint="#6200EE" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Note"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btnLayoutToggle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Convenient"
            android:textSize="11sp"
            android:textColor="#6200EE"
            android:backgroundTint="#EDE7F6"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8942;"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:backgroundTint="#6200EE" />

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnSelect"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Select" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnDraw"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Draw" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnText"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Text" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnQuickEraser"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Erase" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnInsert"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Insert" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnTools"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Tools" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnUndo"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Undo" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnRedo"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Redo" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnExpand"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="More" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp"
                android:backgroundTint="#882196F3" android:textColor="#FFFFFF" />

        </LinearLayout>
    </HorizontalScrollView>

    <HorizontalScrollView
        android:id="@+id/toolbarScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EEEEEE"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnShapes"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Shapes" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnArc"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Arc" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnAutoSelect"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="AutoSel" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnQuickColor"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Color" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnQuickSize"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Size" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

            <Button android:id="@+id/btnQuickFill"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Fill" android:textSize="13sp"
                android:minWidth="0dp" android:paddingStart="10dp" android:paddingEnd="10dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/canvasContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.enginotes.app.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

</LinearLayout>
