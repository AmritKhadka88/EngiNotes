<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F2EE">

    <FrameLayout
        android:id="@+id/canvasContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.enginotes.app.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@drawable/pill_surface"
            android:elevation="5dp"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_select"
                android:rotation="135"
                android:scaleType="centerInside"
                android:padding="7dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Note"
                android:textSize="14sp"
                android:textColor="#1C1C1E"
                android:fontFamily="sans-serif-medium"
                android:maxWidth="150dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingStart="4dp" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@drawable/pill_surface"
            android:elevation="5dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnLayoutToggle"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_size"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageButton
                android:id="@+id/btnLink"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_link"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_tools"
                android:scaleType="centerInside"
                android:padding="9dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>

    <!-- RIGHT EDGE SCROLL TRACK -->
    <FrameLayout
        android:layout_width="16dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginEnd="3dp"
        android:layout_marginTop="64dp"
        android:layout_marginBottom="152dp">

        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/scroll_track"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp" />

        <View
            android:id="@+id/pageScrollThumb"
            android:layout_width="14dp"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal|top"
            android:background="@drawable/scroll_thumb" />
    </FrameLayout>

    <!-- CONTEXT BAR — always visible, scrollable, rebuilds per tool -->
    <HorizontalScrollView
        android:id="@+id/toolbarScroll"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="82dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/card_surface"
        android:elevation="6dp"
        android:scrollbars="none"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <!-- PRIMARY TOOLBAR — scrollable, large icons -->
    <HorizontalScrollView
        android:id="@+id/primaryToolbarScroll"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/toolbar_primary_bg"
        android:elevation="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <ImageButton android:id="@+id/btnSelect"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_select" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnText"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_text" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnDraw"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_pen" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnQuickEraser"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_eraser" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnHighlighter"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_highlighter" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnBrush"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_brush" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <View android:layout_width="1dp" android:layout_height="30dp"
                android:background="#DDD9D4" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>

            <ImageButton android:id="@+id/btnInsert"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_insert" android:scaleType="centerInside" android:padding="13dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnTools"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_shapes" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnQuickFill"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_fill" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector" />

            <View android:layout_width="1dp" android:layout_height="30dp"
                android:background="#DDD9D4" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>

            <ImageButton android:id="@+id/btnUndo"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_undo" android:scaleType="centerInside" android:padding="13dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnRedo"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_redo" android:scaleType="centerInside" android:padding="13dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnTouchToggle"
                android:layout_width="53dp" android:layout_height="53dp"
                android:src="@drawable/ic_select" android:scaleType="centerInside" android:padding="12dp"
                android:background="@drawable/btn_toolbar_selector"
                android:contentDescription="Toggle touch/pan" />

            <!-- Hidden expand button kept for code compatibility -->
            <ImageButton android:id="@+id/btnExpand"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"
                android:src="@drawable/ic_expand"
                android:background="@drawable/btn_toolbar_selector" />

        </LinearLayout>
    </HorizontalScrollView>

</FrameLayout>
