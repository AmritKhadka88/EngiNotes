<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:background="#FAF6EF">

    <!-- Canvas now fills the ENTIRE screen — the bars below float on top of it as overlays,
         instead of squeezing it into a middle row. This is what makes real backdrop blur (and
         the floating "glass panel over content" look) possible in the first place. -->
    <FrameLayout
        android:id="@+id/canvasContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.enginotes.app.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/pageScrollThumb"
            android:layout_width="6dp"
            android:layout_height="40dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="2dp"
            android:layout_marginTop="60dp"
            android:background="#44000000"
            android:visibility="visible" />

    </FrameLayout>

    <!-- Top bar: now a floating overlay pinned to the top instead of a separate row. -->
    <LinearLayout
        android:id="@+id/topBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="New Note" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnLayoutToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_paper"
            android:scaleType="centerInside"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Layout" />

        <TextView
            android:id="@+id/btnScaleRatio"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="1:1"
            android:textSize="12sp"
            android:textColor="#3C3C3E"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/btn_pill_selector"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Drawing Scale" />

        <TextView
            android:id="@+id/btnDimToggle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Dim"
            android:textSize="12sp"
            android:textColor="#3C3C3E"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/btn_pill_selector"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Dimension Mode" />

        <TextView
            android:id="@+id/btnLock"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="🔓"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:visibility="gone"
            android:background="@drawable/btn_pill_selector"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Lock selection" />

        <ImageButton
            android:id="@+id/btnLink"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_link"
            android:scaleType="centerInside"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Insert Link" />

        <ImageButton
            android:id="@+id/btnTouchToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_finger"
            android:scaleType="centerInside"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle touch/pan" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu" />

    </LinearLayout>

    <!-- Primary toolbar: floating overlay pinned to the bottom. -->
    <HorizontalScrollView
        android:id="@+id/primaryToolbarScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:scrollbars="none"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <ImageButton android:id="@+id/btnSelect"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_select" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnText"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_text" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnDraw"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_pen" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnHighlighter"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_highlighter" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnBrush"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_brush" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnQuickEraser"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_eraser" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnQuickFill"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_fill" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnInsert"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_insert" android:scaleType="centerInside" android:padding="10dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnTools"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_shapes" android:scaleType="centerInside" android:padding="9dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnUndo"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_undo" android:scaleType="centerInside" android:padding="10dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnRedo"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_redo" android:scaleType="centerInside" android:padding="10dp"
                android:background="@drawable/btn_pill_selector" />

            <ImageButton android:id="@+id/btnExpand"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_expand" android:scaleType="centerInside" android:padding="10dp"
                android:background="@drawable/btn_pill_selector" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Secondary/context toolbar row: floating overlay pinned to the bottom, sitting directly
         above the primary toolbar (58dp margin ~ primary toolbar's rendered height: 44dp buttons
         + 5dp top/bottom padding). MainActivity.kt already repositions this dynamically when the
         primary toolbar is hidden/shown, so this margin is just the correct default resting spot. -->
    <HorizontalScrollView
        android:id="@+id/toolbarScroll"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="58dp"
        android:background="#FFFFFF"
        android:scrollbars="none"
        android:visibility="visible"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:elevation="5dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <ImageButton android:id="@+id/btnQuickColor"
                android:layout_width="38dp" android:layout_height="38dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_color" android:scaleType="centerInside" android:padding="7dp"
                android:background="@drawable/btn_toolbar_selector" />

            <ImageButton android:id="@+id/btnQuickSize"
                android:layout_width="38dp" android:layout_height="38dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_size" android:scaleType="centerInside" android:padding="8dp"
                android:background="@drawable/btn_toolbar_selector" />

        </LinearLayout>
    </HorizontalScrollView>

</FrameLayout>
